<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
      <TargetFramework>net10.0</TargetFramework>
      <ImplicitUsings>enable</ImplicitUsings>
      <Nullable>enable</Nullable>
      <OutputType>Exe</OutputType>
      <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
      <CompilerGeneratedFilesOutputPath>obj/generated</CompilerGeneratedFilesOutputPath>
      <IsPackable>false</IsPackable>
   </PropertyGroup>

   <ItemGroup>
     <PackageReference Include="Beskar.CodeGeneration.EnumGenerator" />
     <PackageReference Include="Beskar.CodeGeneration.LanguageGenerator" />
     <PackageReference Include="Beskar.CodeGeneration.ObserveGenerator" />
     <PackageReference Include="Beskar.CodeGeneration.PacketGenerator" />
     <PackageReference Include="Beskar.CodeGeneration.ProcessorGenerator" />
     <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
     <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
   </ItemGroup>

   <ItemGroup>
     <None Update="Translations\Translation.en.json">
       <CopyToOutputDirectory>Always</CopyToOutputDirectory>
     </None>
   </ItemGroup>
</Project>
